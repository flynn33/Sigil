{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yggdrasil Cosmology Schema",
  "description": "Validates canonical-pattern-vectors.json and timeline.json",
  "type": "object",
  "required": ["version", "description"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "entities": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "name", "vector", "primary_plane"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 3 },
          "vector": {
            "type": "object",
            "required": ["H_entropy", "K_complexity", "D_fractal_dim", "S_symmetry", "L_generator_length"],
            "properties": {
              "H_entropy": { "type": "number", "minimum": 0, "maximum": 1 },
              "K_complexity": { "type": "number", "minimum": 0, "maximum": 1 },
              "D_fractal_dim": { "type": "number", "minimum": 1, "maximum": 3 },
              "S_symmetry": { "type": "number", "minimum": 0, "maximum": 1 },
              "L_generator_length": { "type": "integer", "minimum": 1, "maximum": 999 }
            }
          },
          "primary_plane": { "type": "integer", "minimum": 1, "maximum": 9 },
          "secondary_plane": { "type": ["integer", "null"], "minimum": 1, "maximum": 9 },
          "ascent_target": { "type": ["integer", "null"], "minimum": 1, "maximum": 9 },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "pattern_vector"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-8]$" },
          "name": { "type": "string", "minLength": 5 },
          "description": { "type": "string", "minLength": 20 },
          "pattern_vector": {
            "type": "object",
            "required": ["H", "K", "D", "S", "L"],
            "properties": {
              "H": { "type": "number", "minimum": 0, "maximum": 1 },
              "K": { "type": "number", "minimum": 0, "maximum": 1 },
              "D": { "type": "number", "minimum": 1, "maximum": 3 },
              "S": { "type": "number", "minimum": 0, "maximum": 1 },
              "L": { "type": "integer", "minimum": 1, "maximum": 999 }
            }
          }
        }
      }
    }
  },
  "oneOf": [
    { "required": ["entities"] },
    { "required": ["phases"] }
  ]
}
