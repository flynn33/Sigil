    "algorithm": {
      "algorithm_name": "CelestialNameGenerationAlgorithm",
      "version": "1.0.1",
      "description": "Algorithm for computing celestial name, epithet, and numerology information based on the Celestial Name Generator model.",
      "input_fields": [
        "heritage",
        "birth_date",
        "birth_weekday",
        "birth_time",
        "hair_color",
        "eye_color",
        "mortal_name"
      ],
      "output_fields": [
        "celestial_name",
        "epithet",
        "dominant_plane",
        "dominant_plane_text",
        "wolf_balance_category",
        "wolf_balance_text",
        "weekday_text",
        "heritage_used",
        "numerology_text",
        "debug_metadata"
      ],
      "steps": [
        {
          "step": "parse_input",
          "actions": [
            "Normalize all strings to lowercase where applicable.",
            "Ensure birth_date is YYYY-MM-DD.",
            "Ensure birth_time is HH:MM.",
            "If heritage items do not match known values, map them to 'other'."
          ]
        },
        {
          "step": "compute_life_path_number",
          "actions": [
            "Extract digits from birth_date.",
            "life_path_sum = sum(all digits).",
            "While life_path_sum > 9, repeat life_path_sum = sum(digits).",
            "Store life_path_number."
          ]
        },
        {
          "step": "determine_dominant_plane",
          "actions": [
            "Find plane where numerology_values contains life_path_number.",
            "Assign dominant_plane_code and dominant_plane_name from model.planes.",
            "Assign dominant_plane_text from model.numerology_output_fragments.planes[dominant_plane_code]."
          ]
        },
        {
          "step": "bucket_birth_time",
          "actions": [
            "Convert birth_time to minutes.",
            "Compare with model.inputs.birth_time.buckets.",
            "Assign birth_time_bucket."
          ]
        },
        {
          "step": "compute_wolf_balance_score",
          "actions": [
            "Start wolf_score = wolf_balance_rules.base_score.",
            "Add hair modifier using wolf_balance_rules.hair_modifiers[hair_color].",
            "Add eye modifier using wolf_balance_rules.eye_modifiers[eye_color].",
            "Add birth time modifier using wolf_balance_rules.birth_time_modifiers[birth_time_bucket].",
            "Add life path modifier using wolf_balance_rules.life_path_modifiers[String(life_path_number)].",
            "If wolf_score >= thresholds.white_dominant, category = 'white_dominant'.",
            "Else if wolf_score <= thresholds.dark_dominant, category = 'dark_dominant'.",
            "Else category = 'balanced'.",
            "Assign wolf_balance_text from model.numerology_output_fragments.wolf_balance[category]."
          ]
        },
        {
          "step": "determine_weekday_archetype",
          "actions": [
            "Use model.weekday_archetypes[birth_weekday] to assign role_bias and tone.",
            "Assign weekday_text from model.numerology_output_fragments.weekday[birth_weekday]."
          ]
        },
        {
          "step": "select_primary_heritage_family",
          "actions": [
            "If user provided multiple heritages, prioritize in order: scandinavian, celtic, germanic, other.",
            "If none match, use 'generic_northern'.",
            "Assign primary_heritage and load heritage_families[primary_heritage].syllable_bias and epithet_flavor."
          ]
        },
        {
          "step": "build_celestial_name_components",
          "actions": [
            "Initialize empty syllable list.",
            "Select 1 root syllable from syllables.root.neutral (biased by heritage if desired).",
            "Select 1 plane syllable from syllables.plane[dominant_plane_code].",
            "If wolf_balance_category == 'white_dominant', choose 0–1 syllables from syllables.wolf.white.",
            "If wolf_balance_category == 'dark_dominant', choose 0–1 syllables from syllables.wolf.dark.",
            "If wolf_balance_category == 'balanced', choose 0–1 syllables from syllables.wolf.balanced.",
            "Ensure final syllable count is within min_syllables and max_syllables from name_structure_rules.celestial_name.length_preference."
          ]
        },
        {
          "step": "assemble_celestial_name",
          "actions": [
            "Capitalize each syllable.",
            "Optionally insert apostrophe before final syllable based on internal rule.",
            "Join syllables according to join_style 'camelcase_with_optional_apostrophe'.",
            "Store as celestial_name."
          ]
        },
        {
          "step": "select_epithet_template",
          "actions": [
            "Initialize empty matching_templates.",
            "For each template in model.epithet_templates:",
            "  If conditions.dominant_plane exists and != dominant_plane_code, skip.",
            "  If conditions.dominant_plane_any_of exists and dominant_plane_code not in list, skip.",
            "  If conditions.role_bias_any_of exists and weekday_archetypes[birth_weekday].role_bias not in list, skip.",
            "  Otherwise, add template to matching_templates.",
            "If matching_templates not empty, choose one (first or deterministic).",
            "Else use fallback epithet 'The One Who Walks Between Paths'.",
            "Store chosen template text as epithet_base."
          ]
        },
        {
          "step": "personalize_epithet",
          "actions": [
            "Set epithet = epithet_base.",
            "Optionally inject heritage_families[primary_heritage].epithet_flavor words into epithet.",
            "Optionally adjust wording based on wolf_balance_category.",
            "Store epithet."
          ]
        },
        {
          "step": "compose_numerology_text",
          "actions": [
            "Initialize numerology_text as list of strings.",
            "Append dominant_plane_text.",
            "Append wolf_balance_text.",
            "Append weekday_text.",
            "Optionally append short text about primary_heritage.",
            "Join list into final numerology_text with line breaks or spaces."
          ]
        },
        {
          "step": "assemble_output",
          "actions": [
            "Create output object.",
            "Set celestial_name, epithet, dominant_plane, dominant_plane_text, wolf_balance_category, wolf_balance_text, weekday_text, heritage_used, numerology_text.",
            "Set debug_metadata including wolf_score, life_path_number, birth_time_bucket.",
            "Return output."
          ]
        }
      ]
    },
    "math": {
      "life_path_formula": {
        "description": "Sum all digits in YYYYMMDD, repeating until a single digit remains.",
        "example": "1977-11-04 -> 1+9+7+7+1+1+0+4 = 30 -> 3+0 = 3"
      },
      "wolf_balance_equation": {
        "description": "Weighted additive scoring system using hair, eye, time-of-day and life path modifiers.",
        "formula": "wolf_score = base_score + hair_mod + eye_mod + time_mod + life_path_mod",
        "threshold_logic": {
          "white_dominant": "wolf_score >= thresholds.white_dominant",
          "balanced": "thresholds.balanced_lower < wolf_score < thresholds.balanced_upper",
          "dark_dominant": "wolf_score <= thresholds.dark_dominant"
        }
      },
      "plane_mapping_math": {
        "description": "Life path number (1–9) maps to a plane where that number exists in numerology_values.",
        "mapping_rule": "dominant_plane = first plane where life_path_number is in plane.numerology_values"
      },
      "syllable_selection_math": {
        "description": "Deterministic or random selection of syllables biased by heritage and plane.",
        "rules": {
          "root_cluster": "Select one from syllables.root.neutral, optionally weighted by heritage syllable_bias.",
          "plane_cluster": "Select one from syllables.plane[dominant_plane].",
          "wolf_cluster": "Select zero or one from the appropriate syllables.wolf group based on wolf_balance_category."
        }
      },
      "name_joining_math": {
        "description": "CamelCase concatenation with an optional apostrophe before final syllable.",
        "pseudo": "Name = Capitalize(root) + (\"'\" optional) + Capitalize(plane) + Capitalize(wolf_if_present)"
      }
    }
  }
}