      "K": [0.0, -1.02]
    },
    "primitives": [
      {"type": "line", "from": [0.0, 0.18], "to": [0.0, -1.02], "samples": 54},
      {"type": "line", "from_ref": "A", "to_ref": "B", "samples": 48},
      {"type": "line", "from_ref": "A", "to_ref": "C", "samples": 36},
      {"type": "line", "from_ref": "B", "to_ref": "C", "samples": 36},
      {"type": "line", "from_ref": "C", "to_ref": "D", "samples": 28},
      {"type": "line", "from_ref": "C", "to_ref": "E", "samples": 28},
      {"type": "line", "from_ref": "F", "to_ref": "H", "samples": 30},
      {"type": "line", "from_ref": "G", "to_ref": "H", "samples": 30},
      {"type": "line", "from_ref": "H", "to_ref": "I", "samples": 32},
