{
  "schema": "wrw.sigil9d.portable.v1",
  "id": "sigil-primary-star-with-two-wolves-9d-projection",
  "version": "1.0.0",
  "portable_intent": "Agent-agnostic JSON spec for generating the WRW sigil as a 2D projection of 9D tubes.",
  "source_context": {
    "project": "Where Ravens Wait",
    "canonical_symbols": {
      "primary_sigil": "Two wolves-one dark, one white-circling a single star.",
      "inscription": "Balance is not kept by opposition, but by remembrance."
    }
  },
  "coordinate_system": {
    "base_space": "normalized_2d",
    "x_range": [-1.0, 1.0],
    "y_range": [-1.2, 1.2],
    "origin": "center",
    "y_axis": "up"
  },
  "dimensions": {
    "ambient": 9,
    "visible": [0, 1],
    "hidden": [2, 3, 4, 5, 6, 7, 8],
    "plane_index_map": {
      "0": "P1_Physical",
      "1": "P2_Etheric",
      "2": "P3_Astral",
      "3": "P4_Mental",
      "4": "P5_Causal",
      "5": "P6_Celestial",
      "6": "P7_Shadow",
      "7": "P8_Void",
      "8": "P9_Divine_Core"
    }
  },
  "canon_defaults": {
    "pattern_vector": {
      "entity": "Nithruun_ThalAzur_Kaelen",
      "H_entropy": 0.55,
      "K_algorithmic_complexity": 0.8,
      "D_fractal_dimension": 1.75,
      "S_symmetry_index": 0.7,
      "L_generator_length": 0.4
    },
    "plane_resonance_weights": [1.0, 0.35, 0.95, 0.9, 0.88, 0.92, 0.42, 0.86, 0.58]
  },
  "formulae": {
    "embedding": {
      "centerline": "v0=x(t), v1=y(t)",
      "hidden": "vk=Ak*sin(2*pi*fk*t+phik), k in {2..8}",
      "notes": "t is global stroke-progress in [0,1]."
    },
    "tube": {
      "surface": "v_tube = v_center + r*omega",
      "omega": "7D section vector over hidden dimensions (unit or normalized)",
      "radius_param": "r >= 0"
    },
    "projection": {
      "equation": "p2 = M(2x9) * v9",
      "matrix_build": "M rows are the first two rows of chained 9D Givens rotations, then elementwise multiplied by plane_resonance_weights."
    },
    "render_glow": {
      "distance_field": "d(x)=min_curve ||x-curve||",
      "intensity": "I(x)=exp(-d(x)^2/(2*sigma^2))"
    }
  },
  "matrix_construction": {
    "givens_rotations_ordered": [
      {"i": 0, "j": 2, "angle_rad": 0.22},
      {"i": 1, "j": 3, "angle_rad": -0.18},
      {"i": 0, "j": 5, "angle_rad": 0.11},
      {"i": 1, "j": 6, "angle_rad": 0.14},
      {"i": 0, "j": 8, "angle_rad": -0.09},
      {"i": 1, "j": 7, "angle_rad": 0.13}
    ],
    "precomputed_weighted_rows": {
      "row_x": [0.966073374918, 0.0, -0.205231130782, 0.0, 0.0, -0.100587278845, 0.0, 0.0, 0.052129558535],
      "row_y": [0.0, 0.338099023272, 0.0, 0.158203851515, 0.0, 0.0, -0.058113566705, -0.111485362653, 0.0]
    }
  },
  "hidden_dimension_profiles": {
    "generator": {
      "fractal_norm": "clamp((D_fractal_dimension-1.0)/1.5,0,1)",
      "components": [
        "H_entropy",
        "K_algorithmic_complexity",
        "fractal_norm",
        "S_symmetry_index",
        "L_generator_length",
        "0.5*(K_algorithmic_complexity+S_symmetry_index)",
        "0.5*(1.0-H_entropy+S_symmetry_index)"
      ],
      "for_offset_0_to_6": {
        "dimension": "2+offset",
        "amplitude": "(0.020+0.060*component[offset]) * plane_weight[dimension]",
        "frequency": "1.00 + 0.37*offset + 0.25*component[offset]",
        "phase": "offset*pi/7"
      }
    },
    "precomputed_defaults": [
      {"dimension": 2, "amplitude": 0.05035, "frequency": 1.1375, "phase": 0.0},
      {"dimension": 3, "amplitude": 0.0612, "frequency": 1.57, "phase": 0.448798950513},
      {"dimension": 4, "amplitude": 0.044, "frequency": 1.865, "phase": 0.897597901026},
      {"dimension": 5, "amplitude": 0.05704, "frequency": 2.285, "phase": 1.346396851538},
      {"dimension": 6, "amplitude": 0.01848, "frequency": 2.58, "phase": 1.795195802051},
      {"dimension": 7, "amplitude": 0.0559, "frequency": 3.0375, "phase": 2.243994752564},
      {"dimension": 8, "amplitude": 0.03161, "frequency": 3.36375, "phase": 2.692793703077}
    ]
  },
  "strokes_2d": {
