        "samples": 70,
        "closed": true
      }
    ]
  },
  "sampling": {
    "global_t_mode": "stroke_index_normalized",
    "global_t_formula": "global_t=(strokeIndex+local_t)/strokeCount",
    "minimum_samples_per_primitive": 2
  },
  "agent_integration": {
    "required_steps": [
      "Build or load 2D primitive samples in listed order.",
      "Map each sample to 9D with embedding formula and hidden profiles.",
      "Optionally offset hidden dimensions with tube radius and section vector.",
      "Project with M and draw polylines in order.",
      "Apply glow pass if desired."
    ],
    "output_expectation": {
      "primary": "2D polyline set",
      "optional": "raster, svg, canvas, or path object"
    }
  }
}
